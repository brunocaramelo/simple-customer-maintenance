APP_NAME=customerMaintancer
APP_ENV=local
APP_KEY='base64:a89Bj62VIrzfDCsb3m8BNU+JedVKtEZEmqif25fR2g0='
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:83

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter

DB_CONNECTION=mysql
DB_HOST=database
DB_PORT=3306
DB_DATABASE=customer_maintancer
DB_USERNAME=sandbox
DB_PASSWORD=sandbox

MYSQL_HOST= mysql

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_DRIVER=redis
CACHE_STORE=redis
CACHE_PREFIX=tasker

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=cache
REDIS_CLIENT=predis
REDIS_USERNAME=default
REDIS_PASSWORD=testes
REDIS_PORT=6380

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

CACHE_DURATION=50000

WEBSERVER_PORT=83
SUPERVISOR_PHP_COMMAND="php -d variables_order=EGPCS /app/artisan octane:start --server=frankenphp --host=0.0.0.0 --admin-port=2019 --port='${WEBSERVER_PORT:-83}'"
XDG_CONFIG_HOME=/var/www/config
XDG_DATA_HOME=/var/www/data
